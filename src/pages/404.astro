---
import TombstoneLayout from '../layouts/TombstoneLayout.astro';
import { url } from '../lib/url';
---

<TombstoneLayout title="404">
  <div class="text-center py-32 px-6">
    <p class="font-mono text-sm text-muted/50 tracking-widest uppercase mb-6">404</p>
    <h1 class="font-serif text-3xl md:text-4xl font-semibold text-text mb-4">
      This grave does not exist.
    </h1>
    <p class="font-serif text-muted italic mb-8">
      Perhaps the company was so imaginary it couldn't even make it to the graveyard.
    </p>
    <a
      href={url('')}
      class="font-serif text-accent hover:text-text transition-colors underline"
    >
      Return to the graveyard
    </a>
  </div>
</TombstoneLayout>
