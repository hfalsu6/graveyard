---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import Hero from '../../components/Hero.astro';
import FeatureBlock from '../../components/FeatureBlock.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';
import { url } from '../../lib/url';

export async function getStaticPaths() {
  const companies = await getCollection('companies');
  return companies.map((company) => ({
    params: { slug: company.data.slug },
    props: { company },
  }));
}

const { company } = Astro.props;
const { Content } = await render(company);
const d = company.data;

---

<BaseLayout
  title={d.name}
  description={`${d.tagline} — ${d.cause_of_death}`}
>
  <SiteHeader />
  <main>
    <!-- Back nav -->
    <div style="padding: 0 2rem 0; max-width: 860px; margin: 0 auto 0;">
      <a
        href={url('')}
        style="color: var(--color-muted); font-family: var(--font-body); font-size: 0.85rem; text-decoration: none; display: inline-flex; align-items: center; gap: 0.4rem;"
      >
        <span style="font-size: 0.8rem;">←</span> All companies
      </a>
    </div>

    <Hero
      name={d.name}
      tagline={d.tagline}
      logo={d.logo}
      logoInitials={d.logo_initials}
      logoColor={d.logo_color}
      foundingYear={d.founding_year}
      deathYear={d.death_year}
      heroHeadline={d.hero_headline}
      heroSubheadline={d.hero_subheadline}
    />

    <FeatureBlock features={d.features} />

    <!-- Pitch body rendered from markdown -->
    <section style="max-width: 660px; margin: 0 auto; padding: clamp(2.5rem, 5vw, 4.5rem) 2rem; border-bottom: 1px solid var(--color-rule);">
      <div class="pitch-body">
        <Content />
      </div>

      <!-- Founder line -->
      <p style="margin-top: 2.5rem; font-family: var(--font-body); font-style: italic; font-size: 0.88rem; color: var(--color-faint);">
        Founded by {d.founder} in {d.founding_year}.
      </p>
    </section>

    <!-- Cause of death -->
    <section style="max-width: 660px; margin: 0 auto; padding: clamp(2rem, 5vw, 4rem) 2rem;">
      <p style="font-family: var(--font-body); font-style: italic; font-size: 1.15rem; color: var(--color-muted); line-height: 1.6;">
        {d.cause_of_death}
      </p>
    </section>

    <!-- Epitaph footer -->
    <div style="max-width: 660px; margin: 0 auto; padding: 0 2rem 5rem;">
      <footer style="border-top: 1px solid var(--color-rule); padding-top: 2.5rem; margin-top: 2rem; text-align: center; display: flex; flex-direction: column; gap: 0.75rem; align-items: center;">
        {d.epitaph && (
          <p style="font-family: var(--font-body); font-style: italic; color: var(--color-muted); font-size: 0.9rem; max-width: 50ch; line-height: 1.6;">
            "{d.epitaph}"
          </p>
        )}
        <p style="font-family: var(--font-mono); font-size: 0.72rem; color: var(--color-faint); letter-spacing: 0.12em; font-weight: 300; margin-top: 0.5rem;">
          RIP {d.founding_year}–{d.death_year}
        </p>
      </footer>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  /* :global() needed because <Content /> renders markdown outside Astro's scoped DOM */
  .pitch-body :global(p) {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.78;
    color: var(--color-muted);
    margin-bottom: 1.4rem;
  }
  .pitch-body :global(p:first-of-type) {
    color: var(--color-text);
  }
  .pitch-body :global(h2) {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: 1.3rem;
    color: var(--color-text);
    margin: 2rem 0 0.75rem;
    letter-spacing: 0.01em;
  }
</style>
