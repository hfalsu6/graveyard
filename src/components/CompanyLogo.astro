---
import { url } from '../lib/url';

interface Props {
  name: string;
  logo?: string;
  logoInitials?: string;
  logoColor?: string;
  size?: number;
}

const { name, logo, logoInitials, logoColor = '#6B7F5C', size = 88 } = Astro.props;
const fontSize = Math.round(size * 0.38);
---

{logoInitials ? (
  <div
    style={`width:${size}px;height:${size}px;background:${logoColor}22;border:1px solid ${logoColor}44;display:flex;align-items:center;justify-content:center;font-family:var(--font-serif);font-weight:500;font-size:${fontSize}px;color:${logoColor};letter-spacing:0.02em;flex-shrink:0;`}
    role="img"
    aria-label={`${name} logo`}
  >
    {logoInitials}
  </div>
) : logo ? (
  <img
    src={url(logo)}
    alt={`${name} logo`}
    style={`width:${size}px;height:${size}px;object-fit:contain;`}
    loading="lazy"
  />
) : null}
