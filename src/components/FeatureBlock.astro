---
interface Props {
  features: { title: string; description: string }[];
}

const { features } = Astro.props;
---

<section style="max-width: 1080px; margin: 0 auto; padding: clamp(2.5rem, 5vw, 4rem) 2rem; border-bottom: 1px solid var(--color-rule);">
  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 2.5rem 3rem;">
    {features.map((feature) => (
      <div>
        <h3 style="font-family: var(--font-serif); font-weight: 500; font-size: 1.2rem; margin-bottom: 0.6rem; letter-spacing: 0.01em; color: var(--color-text);">
          {feature.title}
        </h3>
        <p style="color: var(--color-muted); font-size: 0.92rem; line-height: 1.65; font-family: var(--font-body);">
          {feature.description}
        </p>
      </div>
    ))}
  </div>
</section>
