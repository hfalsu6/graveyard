---
import { url } from '../lib/url';
---

<header style="padding: 4rem 2rem 3rem; text-align: center; border-bottom: 1px solid var(--color-rule); margin-bottom: 4rem;">
  <a href={url('')} style="text-decoration: none; color: inherit;">
    <h1 style="font-family: var(--font-serif); font-weight: 300; font-size: clamp(2rem, 5vw, 3.5rem); letter-spacing: -0.01em; color: var(--color-text); margin-bottom: 0.75rem; line-height: 1.1;">
      Graveyard of Imaginary Companies
    </h1>
  </a>
  <p style="font-family: var(--font-body); font-style: italic; color: var(--color-muted); font-size: 1rem; font-weight: 300;">
    A weekly archive of startups that never were.
  </p>
</header>
